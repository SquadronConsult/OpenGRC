# Copy to `.env` beside `docker-compose.yml` for the all-in-one Docker deployment.
# The container already includes Postgres and its internal DB settings. On first boot,
# the API initializes a fresh Postgres database through the migration path baked into
# the image; you only need to set the values below for sign-in and JWT security.

# Required in production. Used by the API to sign JWTs.
AUTH_JWT_SECRET=change-me-to-a-long-random-string

# Initial admin created automatically when the database is empty.
SEED_ADMIN_EMAIL=admin@localhost
# Min 8 chars. You sign in with this once, then the UI forces you to set your own password.
SEED_ADMIN_PASSWORD=change-me-8-chars-min
