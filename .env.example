# API
# Global HTTP rate limit (JWT and other non-excluded routes). TTL in milliseconds.
# API_THROTTLE_TTL_MS=60000
# API_THROTTLE_LIMIT=120

SEED_ADMIN_EMAIL=admin@localhost
# Min 8 chars. Used on first boot when the users table is empty (auto seed admin for dev/CI).
SEED_ADMIN_PASSWORD=change-me-8-chars-min

# Auth (multi-user JWT sessions)
AUTH_JWT_SECRET=change-me-to-a-long-random-string
# Optional: access token lifetime in seconds (default 7 days)
# AUTH_JWT_EXPIRES_SEC=604800
# Cookie name for httpOnly session (default grc_session)
# AUTH_COOKIE_NAME=grc_session
# First admin when DB is empty: POST /auth/bootstrap with matching token
BOOTSTRAP_TOKEN=

# Legacy: set to local_single_operator only for backward-compat tooling (prefer JWT login).
# AUTH_MODE=

# CORS: comma-separated origins for browser clients (e.g. http://localhost:3001)
# CORS_ORIGIN=http://localhost:3001

DB_TYPE=sqlite
SQLITE_PATH=./grc.sqlite
EVIDENCE_DIR=./evidence
LOCAL_DATA_DIR=.

# Set DB_SYNC=false and DB_MIGRATIONS_RUN=true for migration-driven upgrades (see apps/api/src/data-source.ts).
# DB_MIGRATIONS_RUN=true

# Optional Postgres mode
# DB_TYPE=postgres
# DB_USER=grc
# DB_PASSWORD=grc
# DB_NAME=grc
# DB_HOST=localhost
# DB_PORT=5432

# FRMR (default local file: $LOCAL_DATA_DIR/FRMR.documentation.json, or cwd if unset)
# FRMR_AUTO_INGEST=false
# FRMR_PREFER_LOCAL=true
# FRMR_OFFLINE_PATH=./FRMR.documentation.json
# FRMR_STORE_RAW=true

# Integrations
INTEGRATION_API_KEY=dev-integration-key
# Optional project-scoped key map for v1 endpoints.
# JSON example: {"<projectId>":"<project-key>"}
# or CSV example: <projectId>:<project-key>,<projectId2>:<project-key2>
# INTEGRATION_PROJECT_KEYS=
# INTEGRATION_V1_RATE_LIMIT_PER_MINUTE=300

# Evidence connectors: scheduled collection every minute (disable in dev if unused)
# CONNECTOR_SCHEDULER=false

# Auto-scoping cloud metadata (optional)
# AUTO_SCOPE_INVENTORY_MODE=metadata   # metadata|live
# AWS_ACCOUNT_ID=123456789012
# AWS_REGIONS=us-east-1,us-west-2
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# MCP server guardrails
# MCP_DRY_RUN_DEFAULT=false
# MCP_MAX_FILES_PER_RUN=25
# MCP_MAX_STEPS_PER_RUN=60
# MCP_COMMAND_TIMEOUT_MS=120000

# Web — pick one:
# A) Split dev servers: browser talks directly to API (use Bearer token from login; set CORS_ORIGIN for web origin).
NEXT_PUBLIC_API_URL=http://localhost:3000
# B) Same-origin /api proxy (Next rewrites to INTERNAL_API_URL). Example:
# NEXT_PUBLIC_API_URL=proxy
# INTERNAL_API_URL=http://127.0.0.1:3000

PUBLIC_API_URL=http://localhost:3000

# Smoke scripts: optional explicit JWT (otherwise SEED_ADMIN_PASSWORD + /auth/login is used)
# API_TOKEN=
