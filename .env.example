# API
SEED_ADMIN_EMAIL=admin@localhost
DB_TYPE=sqlite
SQLITE_PATH=./grc.sqlite
EVIDENCE_DIR=./evidence
LOCAL_DATA_DIR=.

# Optional Postgres mode
# DB_TYPE=postgres
# DB_USER=grc
# DB_PASSWORD=grc
# DB_NAME=grc
# DB_HOST=localhost
# DB_PORT=5432

# FRMR
# FRMR_AUTO_INGEST=false
# FRMR_PREFER_LOCAL=true
# FRMR_OFFLINE_PATH=./data/FRMR.documentation.json
# FRMR_STORE_RAW=true

# Integrations
INTEGRATION_API_KEY=dev-integration-key
# Optional project-scoped key map for v1 endpoints.
# JSON example: {"<projectId>":"<project-key>"}
# or CSV example: <projectId>:<project-key>,<projectId2>:<project-key2>
# INTEGRATION_PROJECT_KEYS=
# INTEGRATION_V1_RATE_LIMIT_PER_MINUTE=300

# Auto-scoping cloud metadata (optional)
# AUTO_SCOPE_INVENTORY_MODE=metadata   # metadata|live
# AWS_ACCOUNT_ID=123456789012
# AWS_REGIONS=us-east-1,us-west-2
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# MCP server guardrails
# MCP_DRY_RUN_DEFAULT=false
# MCP_MAX_FILES_PER_RUN=25
# MCP_MAX_STEPS_PER_RUN=60
# MCP_COMMAND_TIMEOUT_MS=120000

# Web (browser must reach API)
NEXT_PUBLIC_API_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000
